{
  "name": "Basic Income Chain",
  "description": "Uplink -> Storage -> Data Broker. Tests full data flow and credit generation.",
  "actions": [
    {"action": "place", "building": "uplink", "cell": [10, 12], "id": "up1"},
    {"action": "place", "building": "storage", "cell": [12, 12], "id": "st1"},
    {"action": "place", "building": "data_broker", "cell": [14, 12], "id": "db1"},
    {"action": "connect", "from": "up1", "from_port": "right", "to": "st1", "to_port": "left"},
    {"action": "connect", "from": "st1", "from_port": "right", "to": "db1", "to_port": "left"},
    {"action": "snapshot", "label": "initial_setup"},
    {"action": "wait_ticks", "count": 10},
    {"action": "snapshot", "label": "after_10_ticks"},
    {"action": "assert", "check": "building_active", "id": "up1"},
    {"action": "assert", "check": "building_active", "id": "st1"},
    {"action": "assert", "check": "building_active", "id": "db1"},
    {"action": "assert", "check": "credits_gt", "value": 0},
    {"action": "wait_ticks", "count": 50},
    {"action": "snapshot", "label": "after_60_ticks"},
    {"action": "assert", "check": "credits_gt", "value": 20}
  ]
}
