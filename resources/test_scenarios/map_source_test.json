{
  "name": "map_source_test",
  "description": "Tests data source placement, Uplink-source linking, and data flow from source composition",
  "actions": [
    {"action": "place_source", "source": "isp_backbone", "cell": [20, 20], "seed": 42},

    {"action": "place", "building": "uplink", "cell": [24, 20], "id": "up1"},
    {"action": "assert", "check": "uplink_linked", "id": "up1"},

    {"action": "place", "building": "storage", "cell": [26, 20], "id": "st1"},
    {"action": "connect", "from": "up1", "from_port": "right", "to": "st1", "to_port": "left"},

    {"action": "place", "building": "data_broker", "cell": [28, 20], "id": "db1"},
    {"action": "connect", "from": "st1", "from_port": "right", "to": "db1", "to_port": "left"},

    {"action": "wait_ticks", "count": 30},

    {"action": "assert", "check": "credits_gt", "value": 0},
    {"action": "assert", "check": "storage_above", "id": "st1", "value": 0},

    {"action": "snapshot", "label": "source_flow_check"},

    {"action": "place", "building": "uplink", "cell": [30, 30], "id": "up_far"},
    {"action": "assert", "check": "uplink_not_linked", "id": "up_far"}
  ]
}
