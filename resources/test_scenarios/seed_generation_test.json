{
  "name": "seed_generation_test",
  "description": "Tests seed-based procedural map generation: deterministic output, source count, uplink linking",
  "actions": [
    {"action": "generate_map", "seed": 42},
    {"action": "wait_ticks", "count": 2},
    {"action": "assert_source_count", "check": "gte", "value": 10},
    {"action": "assert_source_count", "check": "lte", "value": 25},
    {"action": "snapshot", "label": "after_generation"},

    {"action": "place_source", "source": "isp_backbone", "cell": [20, 20], "seed": 42},
    {"action": "place", "building": "uplink", "cell": [21, 19], "id": "up1"},
    {"action": "wait_ticks", "count": 2},
    {"action": "assert", "check": "uplink_linked", "id": "up1"},

    {"action": "place", "building": "storage", "cell": [23, 19], "id": "st1"},
    {"action": "connect", "from": "up1", "from_port": "right", "to": "st1", "to_port": "left"},
    {"action": "wait_ticks", "count": 15},
    {"action": "assert", "check": "storage_above", "id": "st1", "value": 0},
    {"action": "snapshot", "label": "uplink_producing"}
  ]
}
