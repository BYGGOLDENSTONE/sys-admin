{
  "name": "splitter_merger_test",
  "actions": [
    {"action": "place", "building": "uplink", "cell": [5, 5], "id": "up1"},
    {"action": "place", "building": "splitter", "cell": [8, 5], "id": "spl1"},
    {"action": "place", "building": "storage", "cell": [10, 5], "id": "st1"},
    {"action": "place", "building": "storage", "cell": [8, 7], "id": "st2"},

    {"action": "connect", "from": "up1", "from_port": "right", "to": "spl1", "to_port": "left"},
    {"action": "connect", "from": "spl1", "from_port": "right", "to": "st1", "to_port": "left"},
    {"action": "connect", "from": "spl1", "from_port": "bottom", "to": "st2", "to_port": "left"},

    {"action": "wait_ticks", "count": 30},
    {"action": "snapshot", "label": "splitter_30_ticks"},

    {"action": "assert", "check": "building_active", "id": "spl1"},
    {"action": "assert", "check": "storage_above", "id": "st1", "value": 0},
    {"action": "assert", "check": "storage_above", "id": "st2", "value": 0},

    {"action": "place", "building": "uplink", "cell": [5, 11], "id": "up2"},
    {"action": "place", "building": "uplink", "cell": [5, 13], "id": "up3"},
    {"action": "place", "building": "merger", "cell": [8, 12], "id": "mrg1"},
    {"action": "place", "building": "storage", "cell": [10, 11], "id": "st3"},

    {"action": "connect", "from": "up2", "from_port": "right", "to": "mrg1", "to_port": "left"},
    {"action": "connect", "from": "up3", "from_port": "right", "to": "mrg1", "to_port": "top"},
    {"action": "connect", "from": "mrg1", "from_port": "right", "to": "st3", "to_port": "left"},

    {"action": "wait_ticks", "count": 30},
    {"action": "snapshot", "label": "merger_30_ticks"},

    {"action": "assert", "check": "building_active", "id": "mrg1"},
    {"action": "assert", "check": "storage_above", "id": "st3", "value": 0}
  ]
}
