    {"action": "assert", "check": "building_active", "id": "sep1"},
    {"action": "assert", "check": "building_active", "id": "comp1"},
    {"action": "assert", "check": "credits_gt", "value": 0},
    {"action": "assert", "check": "storage_above", "id": "st_other", "value": 0}
  ]
