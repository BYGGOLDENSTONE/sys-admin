{
  "name": "exploration_test",
  "description": "Tests source discovery: Ring 0 auto-discovered, Ring 1+ hidden until building placed within 20 cells",
  "actions": [
    {"action": "generate_map", "seed": 42},
    {"action": "wait_ticks", "count": 1},

    {"action": "assert", "check": "discovered_sources_gte", "value": 7},
    {"action": "assert", "check": "undiscovered_sources_gte", "value": 10},

    {"action": "place", "building": "storage", "cell": [155, 148], "id": "st_discover"},
    {"action": "assert", "check": "discovered_sources_gte", "value": 8},

    {"action": "place", "building": "storage", "cell": [10, 10], "id": "st_far"},
    {"action": "assert", "check": "discovered_sources_gte", "value": 8},
    {"action": "assert", "check": "undiscovered_sources_gte", "value": 5},

    {"action": "snapshot", "label": "exploration_check"}
  ]
}
